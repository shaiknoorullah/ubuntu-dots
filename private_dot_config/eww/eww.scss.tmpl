// ─────────────────────────────────────────────────────────────
// EWW — Dracula+  (chezmoi template)
// Generated from .chezmoidata.yaml — DO NOT hand-edit hex below.
// One palette → all widgets. Add new colors to .chezmoidata.yaml.
// ─────────────────────────────────────────────────────────────

// ── Dracula tokens (templated) ───────────────────────────────
$base:      #{{ .dracula.base }};
$bg:        #{{ .dracula.bg }};
$fg:        #{{ .dracula.fg }};
$comment:   #{{ .dracula.comment }};
$selection: #{{ .dracula.selection }};
$surface0:  #{{ .dracula.surface0 }};
$surface1:  #{{ .dracula.surface1 }};
$surface2:  #{{ .dracula.surface2 }};
$subtext0:  #{{ .dracula.subtext0 }};
$purple:    #{{ .dracula.purple }};
$pink:      #{{ .dracula.pink }};
$blue:      #{{ .dracula.blue }};
$cyan:      #{{ .dracula.cyan }};
$green:     #{{ .dracula.green }};
$orange:    #{{ .dracula.orange }};
$red:       #{{ .dracula.red }};
$yellow:    #{{ .dracula.yellow }};

// ── Derived aliases / alpha-ladder (ported from mockup) ───────
// Mockup --fg-dim / --muted / glass / surfaces / accent-ladder / radii.
$fg-dim:  rgba(248, 248, 242, 0.55);
$muted:   $comment;

// glass surfaces (mockup --glass / --glass2)
$glass:   rgba(40, 42, 54, 0.72);
$glass2:  rgba(30, 31, 42, 0.85);

// neutral surface ladder (mockup --s1 / --s2 / --bd / --hov)
$s1:  rgba(248, 248, 242, 0.04);
$s2:  rgba(248, 248, 242, 0.07);
$bd:  rgba(248, 248, 242, 0.09);
$hov: rgba(248, 248, 242, 0.10);

// purple accent ladder (mockup --a12 / --a18 / --a35)
$a12: rgba(189, 147, 249, 0.12);
$a18: rgba(189, 147, 249, 0.18);
$a35: rgba(189, 147, 249, 0.35);

// radii (mockup: card 16 / bar 24 / pill 99)
$rad:    16px;   // cards
$radbar: 24px;   // bars
$pill:   99px;   // pills
$chip:   9px;    // chips

// ─────────────────────────────────────────────────────────────
// Base
// ─────────────────────────────────────────────────────────────

window {
  background-color: transparent;
}

window button {
  all: unset;
  background: none;
  background-image: none;
  box-shadow: none;
  border: none;
}

// ─────────────────────────────────────────────────────────────
// Notification Center — Panel  (PRESERVED)
// ─────────────────────────────────────────────────────────────

.panel {
  background-color: rgba(20, 19, 19, 0.78);
  border-radius: 16px;
  border: 1px solid rgba(189, 147, 249, 0.1);
  padding: 14px;
}

// ─────────────────────────────────────────────────────────────
// Notification Center — Header
// ─────────────────────────────────────────────────────────────

.header {
  padding: 2px 4px 10px 4px;
  margin-bottom: 8px;
  border-bottom: 1px solid rgba(88, 88, 128, 0.15);
}

.header-icon {
  color: $purple;
  font-size: 15px;
  margin-right: 8px;
}

.header-title {
  color: $fg;
  font-size: 13px;
  font-weight: bold;
}

.header-count {
  color: $muted;
  font-size: 10px;
  background-color: rgba(88, 88, 128, 0.12);
  border-radius: 10px;
  padding: 2px 8px;
}

// ─────────────────────────────────────────────────────────────
// Notification Center — Stack (group container)
// ─────────────────────────────────────────────────────────────

.stack {
  border-radius: 12px;
}

.stack-indicator {
  background-color: rgba(30, 30, 52, 0.3);
  border-radius: 0px 0px 10px 10px;
  min-height: 6px;
  margin-left: 8px;
  margin-right: 8px;
  margin-top: -8px;
  border-left: 1px solid rgba(88, 88, 128, 0.06);
  border-right: 1px solid rgba(88, 88, 128, 0.06);
  border-bottom: 1px solid rgba(88, 88, 128, 0.06);
}

.stack-expanded {
  margin-top: 4px;
}

// ─────────────────────────────────────────────────────────────
// Notification Center — Card
// ─────────────────────────────────────────────────────────────

.card {
  background-color: rgba(35, 35, 58, 0.5);
  border-radius: 12px;
  border: 1px solid rgba(88, 88, 128, 0.08);
  padding: 10px 12px;
}

.card-nested {
  background-color: rgba(35, 35, 58, 0.35);
  border-radius: 8px;
  padding: 8px 10px;
}

.card-icon {
  background-color: rgba(189, 147, 249, 0.1);
  color: $purple;
  font-size: 15px;
  border-radius: 15px;
  min-width: 30px;
  min-height: 30px;
  margin-right: 10px;
}

.card-app {
  color: $purple;
  font-size: 10px;
  font-weight: bold;
}

.card-count {
  color: $muted;
  font-size: 9px;
  background-color: rgba(88, 88, 128, 0.15);
  border-radius: 8px;
  padding: 1px 6px;
  margin-right: 6px;
}

.card-time {
  color: $muted;
  font-size: 9px;
}

.card-summary {
  color: $fg;
  font-size: 11px;
  font-weight: bold;
  margin-top: 2px;
}

.card-body {
  color: $fg-dim;
  font-size: 10px;
  margin-top: 3px;
}

.card-dismiss {
  all: unset;
  background: none;
  background-image: none;
  box-shadow: none;
  border: none;
  border-radius: 6px;
  color: transparent;
  min-width: 18px;
  min-height: 18px;
  font-size: 10px;
}

.stack:hover .card-dismiss {
  color: $muted;
}

.card-dismiss:hover {
  color: $red;
  background-color: rgba(255, 77, 77, 0.1);
}

// ─────────────────────────────────────────────────────────────
// Notification Center — Status Bar
// ─────────────────────────────────────────────────────────────

.status-bar {
  margin-top: 10px;
  padding-top: 8px;
  border-top: 1px solid rgba(88, 88, 128, 0.15);
}

.status-btn {
  background-color: rgba(88, 88, 128, 0.08);
  color: $muted;
  border: none;
  border-radius: 18px;
  padding: 5px 14px;
  font-size: 11px;
}

.status-btn:hover {
  background-color: rgba(88, 88, 128, 0.18);
  color: $fg;
}

.status-btn-active {
  background-color: rgba(255, 158, 59, 0.12);
  color: $orange;
}

.status-btn-active:hover {
  background-color: rgba(255, 158, 59, 0.22);
}

.status-btn-danger:hover {
  background-color: rgba(255, 77, 77, 0.12);
  color: $red;
}

// ─────────────────────────────────────────────────────────────
// Notification Center — Empty State
// ─────────────────────────────────────────────────────────────

.empty {
  padding: 60px 0px;
}

.empty-icon {
  color: rgba(88, 88, 128, 0.4);
  font-size: 36px;
  margin-bottom: 10px;
}

.empty-text {
  color: $muted;
  font-size: 12px;
}

// ─────────────────────────────────────────────────────────────
// Widget partials  (imported AFTER token vars so $vars resolve)
// ─────────────────────────────────────────────────────────────

@import "widgets/topbar";
@import "widgets/island";
@import "widgets/bottombar";
@import "widgets/leftbar";
