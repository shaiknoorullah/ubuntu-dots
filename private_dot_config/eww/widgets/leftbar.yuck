;; ─────────────────────────────────────────────────────────────
;; leftbar — the summoned "what am I chasing?" panel (mockup #left)
;;
;; Slides in from the left (revealer in eww.yuck, driven by `leftbar_open`).
;; Sections, top→bottom, per the mockup:
;;   head        · title + active-block / next-salah subtitle
;;   timer       · big count-up block (adhd-focus.sh status + live elapsed)
;;   salah       · five-prayer strip (eww-salah.sh)
;;   agent       · master-agent "Ask anything" strip (visual stub; Phase D)
;;   now · next  · taskwarrior rows (eww-tasks.sh — +today / +next)
;;   today       · calendar (stub: a single "today" card + sample rows)
;;   music       · now-playing card (eww-media.sh)
;;   learn       · spaced-repetition chips (stub)
;;
;; All colour comes from `lb-…`-prefixed classes in eww.scss.tmpl. Backends
;; emit JSON/text and degrade gracefully, so the panel always renders.
;; ─────────────────────────────────────────────────────────────

;; ── Data sources ─────────────────────────────────────────────
;; Big-timer line, e.g. "block 47m · → Asr 16:42" or "idle · → Fajr (tmrw)".
(defpoll lb-focus :interval "5s"
  :initial "idle · → —"
  `adhd-focus.sh status`)

;; Live elapsed clock for the active block (reused from the bottom-bar feed).
(defpoll lb-active :interval "2s"
  :initial `{"task":"—","elapsed":"0:00:00"}`
  `eww-active.sh`)

;; Today's five-prayer strip: [{name,time,state}], state ∈ done|next|"".
(defpoll lb-salah-data :interval "30s"
  :initial "[]"
  `eww-salah.sh`)

;; now · next task rows: [{id,desc,meta,active,icon}].
(defpoll lb-tasks-data :interval "5s"
  :initial "[]"
  `eww-tasks.sh`)

;; Now-playing for the music card: {title,artist,status,…} (may be empty).
(defpoll lb-media :interval "2s"
  :initial `{"title":"","artist":"","status":"Stopped"}`
  `eww-media.sh`)

;; ── Section: header ──────────────────────────────────────────
(defwidget lb-head []
  (box :class "lb-head" :orientation "h" :space-evenly false
    (box :orientation "v" :space-evenly false :hexpand true :halign "start"
      (label :class "lb-head-title" :text "What are you chasing?" :halign "start")
      (label :class "lb-head-sub" :text "one block · one outcome" :halign "start"))
    (box :orientation "v" :space-evenly false :halign "end"
      (label :class "lb-head-sub" :text {lb-active.task != "—" ? lb-active.task : "no active block"} :halign "end" :limit-width 22)
      (label :class "lb-head-sub" :text lb-focus :halign "end" :limit-width 26))))

;; ── Section: big timer ───────────────────────────────────────
(defwidget lb-timer []
  (box :class "lb-card lb-timer" :orientation "v" :space-evenly false
    (box :class "lb-ct" :orientation "h" :space-evenly false
      (label :text "deep block" :halign "start" :hexpand true)
      (label :class "lb-ct-accent" :text lb-focus :halign "end" :limit-width 24))
    (label :class "lb-timer-big" :text {lb-active.elapsed} :halign "start")
    (label :class "lb-timer-lbl" :text {lb-active.task} :halign "start" :limit-width 34)
    (label :class "lb-timer-run" :text "runway to next salah · gentle nudge at 90m" :halign "start")
    (box :class "lb-prog" :halign "fill"
      (box :class "lb-prog-fill" :hexpand false))))

;; ── Section: salah strip ─────────────────────────────────────
(defwidget lb-salah []
  (box :class "lb-salah" :orientation "h" :spacing 6 :space-evenly true
    (for p in lb-salah-data
      (label
        :class "lb-salah-pill lb-salah-${p.state == '' ? 'idle' : p.state}"
        :text {p.name}))))

;; ── Section: master-agent strip (visual stub — backend is Phase D) ─
(defwidget lb-agent []
  (box :class "lb-card lb-agent" :orientation "v" :space-evenly false
    (box :class "lb-ct" :orientation "h" :space-evenly false
      (label :text "master agent" :halign "start" :hexpand true)
      (label :class "lb-ct-accent" :text "full context" :halign "end"))
    (box :class "lb-ask" :orientation "h" :space-evenly false
      (label :class "lb-ask-ic" :text "")
      (label :class "lb-ask-text" :text "Ask anything — “summarize my open PRs”" :halign "start" :hexpand true :limit-width 30)
      (label :class "lb-ask-cur" :text "▏"))
    (box :class "lb-models" :orientation "h" :spacing 6 :space-evenly false :halign "start"
      (label :class "lb-model on" :text " Gemini 2.5")
      (label :class "lb-model" :text " Claude")
      (label :class "lb-model" :text "󰧑 local")
      (label :class "lb-model muted" :text "NotebookLM"))))

;; ── Section: now · next tasks ────────────────────────────────
(defwidget lb-tasks []
  (box :class "lb-card lb-tasklist" :orientation "v" :space-evenly false
    (box :class "lb-ct" :orientation "h" :space-evenly false
      (label :text "now · next" :halign "start" :hexpand true))
    (box :orientation "v" :space-evenly false
      (for t in lb-tasks-data
        (box :class "lb-row ${t.active ? 'active' : ''}" :orientation "h" :space-evenly false
          (label :class "lb-row-ic" :text {t.icon})
          (label :class "lb-row-t" :text {t.desc} :halign "start" :hexpand true :limit-width 34)
          (label :class "lb-row-m" :text {t.meta} :halign "end"))))))

;; ── Section: calendar (stub: today label + sample rows) ──────
(defwidget lb-calendar []
  (box :class "lb-card" :orientation "v" :space-evenly false
    (box :class "lb-ct" :orientation "h" :space-evenly false
      (label :text "today" :halign "start" :hexpand true)
      (label :class "lb-ct-accent" :text "calendar" :halign "end"))
    (box :orientation "v" :space-evenly false
      (box :class "lb-row" :orientation "h" :space-evenly false
        (label :class "lb-row-ic lb-ic-green" :text "")
        (label :class "lb-row-t" :text "Standup" :halign "start" :hexpand true)
        (label :class "lb-row-m" :text "done" :halign "end"))
      (box :class "lb-row" :orientation "h" :space-evenly false
        (label :class "lb-row-ic lb-ic-purple" :text "")
        (label :class "lb-row-t" :text "1:1 — review" :halign "start" :hexpand true)
        (label :class "lb-row-m" :text "5:30" :halign "end"))
      (box :class "lb-divider")
      (box :class "lb-row" :orientation "h" :space-evenly false
        (label :class "lb-row-ic" :text "")
        (label :class "lb-row-t" :text "Inbox" :halign "start" :hexpand true)
        (label :class "lb-row-m" :text "pending" :halign "end")))))

;; ── Section: music ───────────────────────────────────────────
(defwidget lb-music []
  (box :class "lb-card lb-music" :orientation "h" :space-evenly false
    (box :class "lb-music-art")
    (box :class "lb-music-mt" :orientation "v" :space-evenly false :hexpand true :halign "start"
      (label :class "lb-music-title"
        :text {lb-media.title != "" ? lb-media.title : "Nothing playing"}
        :halign "start" :limit-width 24)
      (label :class "lb-music-sub"
        :text {lb-media.artist != "" ? lb-media.artist : "—"}
        :halign "start" :limit-width 24))
    (box :class "lb-mctrl" :orientation "h" :spacing 10 :space-evenly false :halign "end"
      (label :text "󰒮")
      (label :text {lb-media.status == "Playing" ? "" : ""})
      (label :text "󰒭"))))

;; ── Section: learning chips (stub) ───────────────────────────
(defwidget lb-learn []
  (box :class "lb-card" :orientation "v" :space-evenly false
    (box :class "lb-ct" :orientation "h" :space-evenly false
      (label :text "learn · in the gaps" :halign "start" :hexpand true)
      (label :class "lb-ct-accent" :text "spaced repetition" :halign "end"))
    (box :class "lb-row" :orientation "h" :space-evenly false
      (label :class "lb-row-ic lb-ic-yellow" :text "󰓆")
      (label :class "lb-row-t" :text "Go generics — constraints" :halign "start" :hexpand true)
      (label :class "lb-row-m" :text "7 due" :halign "end"))
    (box :class "lb-chips" :orientation "h" :spacing 7 :space-evenly false :halign "start"
      (label :class "lb-chip due" :text "review 2 cards · 4 min")
      (label :class "lb-chip" :text "tiny: triage inbox")
      (label :class "lb-chip" :text "CKA: etcd backup"))))

;; ── Composite ────────────────────────────────────────────────
(defwidget leftbar []
  (box :class "leftbar" :orientation "v" :space-evenly false :spacing 11
    (lb-head)
    (lb-timer)
    (lb-salah)
    (lb-agent)
    (lb-tasks)
    (lb-calendar)
    (lb-music)
    (lb-learn)))
