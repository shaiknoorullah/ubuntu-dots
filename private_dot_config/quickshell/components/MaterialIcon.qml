// MATERIAL SYMBOLS ICON  (pattern: caelestia components/MaterialIcon.qml)
// Renders a Material Symbols glyph. Requires the "Material Symbols Rounded"
// font installed. `text` is the icon ligature name, e.g. "play_arrow".

import qs.services

StyledText {
    color: Colours.palette.m3onSurface
    font.family: "Material Symbols Rounded"
    font.pixelSize: 20
}
