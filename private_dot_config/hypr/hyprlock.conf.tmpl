# hyprlock — Dracula lock screen (palette templated from .chezmoidata.yaml).
# Bound to $mod+Escape in hyprland.lua. https://wiki.hypr.land/Hypr-Ecosystem/hyprlock/

general {
    hide_cursor = true
    grace = 0
    ignore_empty_input = true
}

# Blurred snapshot of whatever was on screen.
background {
    monitor =
    path = screenshot
    blur_passes = 3
    blur_size = 8
    noise = 0.012
    contrast = 0.9
    brightness = 0.7
    vibrancy = 0.18
    color = rgb({{ .dracula.base }})
}

# Big clock.
label {
    monitor =
    text = cmd[update:1000] echo "$(date '+%H:%M')"
    color = rgb({{ .dracula.fg }})
    font_size = 96
    font_family = JetBrainsMono Nerd Font
    position = 0, 170
    halign = center
    valign = center
}

# Date.
label {
    monitor =
    text = cmd[update:60000] echo "$(date '+%A, %d %B')"
    color = rgb({{ .dracula.cyan }})
    font_size = 18
    font_family = JetBrainsMono Nerd Font
    position = 0, 95
    halign = center
    valign = center
}

# Gentle prompt (on-brand).
label {
    monitor =
    text = what are you chasing?
    color = rgb({{ .dracula.comment }})
    font_size = 13
    font_family = JetBrainsMono Nerd Font
    position = 0, -10
    halign = center
    valign = center
}

# Password input — Dracula ring.
input-field {
    monitor =
    size = 300, 52
    outline_thickness = 2
    dots_size = 0.28
    dots_spacing = 0.3
    dots_center = true
    rounding = 16
    outer_color = rgb({{ .dracula.purple }})
    inner_color = rgb({{ .dracula.surface0 }})
    font_color = rgb({{ .dracula.fg }})
    font_family = JetBrainsMono Nerd Font
    placeholder_text = <span foreground="##{{ .dracula.comment }}">password</span>
    check_color = rgb({{ .dracula.green }})
    fail_color = rgb({{ .dracula.red }})
    fail_text = <span foreground="##{{ .dracula.red }}">$FAIL ($ATTEMPTS)</span>
    fade_on_empty = false
    position = 0, -65
    halign = center
    valign = center
}
