/*
 * Theme: Firefox Bookmarks Browser
 * Base:  list-menu
 * Overrides: 1-column 12-line list with icons and mode-switcher
 *   disabled for browsing saved bookmarks.
 * Binding: $mod+Shift+o
 * Script:  rofi-bookmarks.sh
 */
@import "shared/list-menu"

listview {
    columns: 1;
    lines: 12;
}

element-icon {
    enabled: false;
}

textbox-prompt-colon {
    str: "󰃃 ";
}

mode-switcher {
    enabled: false;
}
