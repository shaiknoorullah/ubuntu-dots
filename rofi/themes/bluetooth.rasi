/*
 * Theme: Bluetooth Device Manager
 * Base:  list-menu
 * Overrides: 1-column 8-line list with icons and mode-switcher
 *   disabled for a compact device listing.
 * Binding: $mod+Shift+b
 * Script:  rofi-bluetooth.sh
 */
@import "shared/list-menu"

listview {
    columns: 1;
    lines: 8;
}

element-icon {
    enabled: false;
}

textbox-prompt-colon {
    str: " ";
}

mode-switcher {
    enabled: false;
}
