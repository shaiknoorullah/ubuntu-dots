/*
 * Theme: Git Identity Switcher
 * Base:  list-menu
 * Overrides: 1-column 4-line list in a smaller centered box (35% 32%
 *   padding) since there are only a few profiles to show.
 * Binding: $mod+g
 * Script:  rofi-git-profile.sh
 */
@import "shared/list-menu"

listview {
    columns: 1;
    lines: 4;
}

element-icon {
    enabled: false;
}

textbox-prompt-colon {
    str: " ";
}

mode-switcher {
    enabled: false;
}

mainbox {
    padding: 35% 32%;
}
