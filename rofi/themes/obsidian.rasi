/*
 * Theme: Obsidian Quick Actions
 * Base:  list-menu
 * Overrides: 1-column 6-line list in a smaller centered box (35% 30%
 *   padding) for a compact action menu.
 * Binding: $mod+n
 * Script:  rofi-obsidian.sh
 */
@import "shared/list-menu"

listview {
    columns: 1;
    lines: 6;
}

element-icon {
    enabled: false;
}

textbox-prompt-colon {
    str: "󱓧 ";
}

mode-switcher {
    enabled: false;
}

mainbox {
    padding: 35% 30%;
}
