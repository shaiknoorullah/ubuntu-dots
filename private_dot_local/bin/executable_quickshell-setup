#!/usr/bin/env bash
# Reproducibly (re)create the Arch distrobox that runs the quickshell 3-bar shell.
# quickshell needs Qt6.6+ which Ubuntu 24.04 lacks, so it runs from Arch with
# host Wayland+nvidia passthrough. Re-run any time to rebuild the container.
set -e

distrobox create --name arch --image archlinux:latest --nvidia --yes 2>/dev/null \
  || echo "(arch box already exists)"

# quickshell + the Qt6 modules the shell imports, plus the host-side CLI tools the
# data services shell out to (they read the shared $HOME: ~/.task, ~/.timewarrior…).
distrobox enter arch -- sudo pacman -Syu --noconfirm \
  quickshell qt6-wayland qt6-svg qt6-imageformats qt6-multimedia qt6-5compat \
  task timew jq playerctl grim

echo "✅ arch distrobox ready — quickshell-launch will render the bars."
